// MITRE ATT&CK: T1218 - mshta Inline Execution

// Detect mshta.exe abuse via inline HTA / suspicious execution
logs_edr_labs_CL
| where process_name_s == "mshta.exe"
| where timestamp between (datetime(2023-07-04T20:20:30Z)
                        .. datetime(2023-07-04T20:20:50Z))
| project timestamp, process_name_s, process_parent_name_s,
          body_s, process_command_line_s
